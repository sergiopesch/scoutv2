{
  "name": "scoutv2",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.23.1 <23",
    "npm": "10.9.8"
  },
  "packageManager": "npm@10.9.8",
  "type": "module",
  "description": "Conversation-aware live business architecture whiteboard",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server/index.js",
    "test": "vitest run",
    "check": "npm test && npm run typecheck && npm run build && git diff --check",
    "typecheck": "tsc --noEmit",
    "eval:transcript": "tsx src/evals/run-transcript-eval.ts",
    "generate:codex-schemas": "codex app-server generate-ts --out src/server/codex/generated"
  },
  "dependencies": {
    "express": "^5.2.1",
    "mermaid": "^11.16.0",
    "svix": "^1.98.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.1",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
