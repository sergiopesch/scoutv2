NODE_ENV=production
PORT=3000
HOST=127.0.0.1
# Required for live Recall mode; leave blank for local rehearsal mode.
PUBLIC_API_BASE_URL=
ANALYSIS_DELAY_MS=8000
ANALYSIS_RERUN_DELAY_MS=2000
ANALYSIS_MAX_BATCH_UTTERANCES=40
ANALYSIS_MAX_BATCH_BYTES=48000
MAX_AUTOMATIC_ANALYSIS_TURNS_PER_SESSION=20
MAX_ACTIVE_SESSIONS=3
MAX_SSE_CONNECTIONS=128
MAX_SSE_CONNECTIONS_PER_SESSION=32
SESSION_RETENTION_MS=14400000
SHUTDOWN_GRACE_MS=60000
SCOUT_ALLOW_DEV_INGEST=false
CODEX_BINARY=codex
CODEX_MODEL=gpt-5.6-sol
CODEX_REASONING_EFFORT=low
# Opt in only after validating structured pain diagnosis with representative calls.
SCOUT_STRUCTURED_DIAGNOSIS=0
RECALL_REGION=us-west-2
RECALL_API_KEY=
RECALL_WORKSPACE_VERIFICATION_SECRET=
# Set only for a legacy dashboard webhook configured with its own Svix secret.
RECALL_SVIX_WEBHOOK_SECRET=
RECALL_OUTPUT_MODE=screenshare
RECALL_REQUEST_TIMEOUT_MS=10000
RECALL_MAX_RETRIES=3
